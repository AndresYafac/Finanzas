VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_publishable_o_anon_key

# Busqueda DNI/RUC con https://dniruc.apisperu.com
# Produccion recomendada: guardar APISPERU_TOKEN como secret de Supabase Edge Functions.
# npx supabase secrets set APISPERU_TOKEN=tu_token_apisperu
APISPERU_TOKEN=tu_token_apisperu

# Compatibilidad local/frontend. En produccion no expongas este token como VITE_.
VITE_APISPERU_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJlbWFpbCI6ImxiYXF1ZWRhbm9Ac29sdW5ldC5jb20ucGUifQ.9Hm4UsyoWgH-PsUlPW5GKVAA1jQKdpdAQO70XbMlMzc

# Alternativa: proveedor propio. Si se define, reemplaza a VITE_APISPERU_TOKEN.
# VITE_DOCUMENT_LOOKUP_URL=https://tu-api-documentos.com/consulta?tipo={tipo}&numero={documento}

# Push notifications. Esta clave publica si puede ir al frontend.
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=tu_vapid_public_key
